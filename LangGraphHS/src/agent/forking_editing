from langgraph.checkpoint.memory import InMemorySaver
from langchain.messages import HumanMessage

from operator import add
from typing import Literal
from typing_extensions import TypedDict, Annotated
from langchain_core.messages import AnyMessage
from langchain.messages import SystemMessage, ToolMessage, HumanMessage

from langgraph.graph import StateGraph, START, END
from langgraph.types import interrupt, Command
from langgraph.func import entrypoint
from langgraph.store.base import BaseStore

from tools_setup import model_with_tools, tools_by_name
from langchain.tools import tool
from langchain.chat_models import init_chat_model


from dotenv import load_dotenv

load_dotenv()


@tool
def calculator(x: int, y: int, operation: str) -> int:
    """
    Perform a basic arithmetic operation on two integers.

    Args:
        x (int): The first numerical operand.
        y (int): The second numerical operand.
        operation (str): The type of math to perform. 
                         Must be one of: 'add', 'subtract', 'multiply', or 'divide'.

    Returns:
        int: The resulting value of the operation.

    Raises:
        ValueError: If an operation outside of the supported list is provided.
        ZeroDivisionError: If 'divide' is called with y = 0.
    """
    if operation == "add":
        return x + y
    elif operation == "subtract":
        return x - y
    elif operation == "multiply":
        return x * y
    elif operation == "divide":
        return x / y
    else:
        raise ValueError("Unsupported operation")
    
    
tools =[calculator]

model = init_chat_model(model="openai:gpt-4.1-mini")
tools_by_name = {t.name: t for t in tools}

model_with_tools = model.bind_tools(tools)

class AgentState(TypedDict):
    messages: Annotated[list[AnyMessage], add]
    
    
def llm_call(state: AgentState):
    """ LLM decide whether to call tools or respond"""
    response = model_with_tools.invoke(
        [SystemMessage(content="You are a helpful assistant that solves arithmetic problem using tools when needed.")]
        + state["messages"]
        )
    return {
        "messages": [response],
    }    
    
    
def haman_review(state: AgentState):
    """Human review after LLM response"""
    last = state["messages"][-1]
    print(f"LLM Response: {last.content}")
    if not last.tool_calls:
        return Command(goto=END)
    print(f"\n[INTERRUPT]: LLM wants to call: {last.tool_calls[0]['args']}")
    decision = interrupt("Approve tool execution?")
    return Command(goto="tool_node" if decision else END)
    
    
def tool_node(state: AgentState):
    last_msg = state["messages"][-1]
    results = []
    for call in last_msg.tool_calls:
        observation = calculator.invoke(call["args"])
        results.append(ToolMessage(content=str(observation), tool_call_id=call["id"]))
    return {"messages": results}    


builder = StateGraph(AgentState)
builder.add_node("llm_call", llm_call)
builder.add_node("haman_review", haman_review)
builder.add_node("tool_node", tool_node)

builder.add_edge(START, "llm_call")
builder.add_edge("llm_call", "haman_review")
builder.add_edge("tool_node", "llm_call")

app = builder.compile(checkpointer=InMemorySaver())


# --- 4. THE FORKING EXERCISE ---
config = {"configurable": {"thread_id": "original_path"}}

# Path A: The LLM suggests 10 * 10
print("--- PATH A: STARTING ---")
result = app.invoke({"messages": [HumanMessage(content="Multiply 10 and 10")]}, config)

while "__interrupt__" in result:
    user_input = input("Approve tool execution? (y/n): ").strip().lower()
    approved = user_input in {"y", "yes"}
    result = app.invoke(Command(resume=approved), config)

if "messages" in result and result["messages"]:
    print("\n--- FINAL RESPONSE ---")
    print(result["messages"][-1].content)
    
